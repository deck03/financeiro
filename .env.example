# Supabase — encontrados em Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de administrador do Supabase — NUNCA exponha no frontend, usar apenas
# em Server Actions/Route Handlers/Edge Functions que rodam no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da aplicação (usada em links de e-mail, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provedor de e-mail (Resend) — usado pelos relatórios automáticos (Fase 11)
RESEND_API_KEY=
EMAIL_FROM=

# Segredo compartilhado que protege a rota do cron de relatórios
# (Vercel Cron envia este valor automaticamente se configurado nas
# variáveis de ambiente do projeto)
CRON_SECRET=
