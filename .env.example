# Supabase — encontrados em Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de administrador do Supabase — NUNCA exponha no frontend, usar apenas
# em Server Actions/Route Handlers/Edge Functions que rodam no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da aplicação (usada em links de e-mail, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provedor de e-mail — usado pelos relatórios automáticos (Fase 11).
# Escolha UMA das duas opções abaixo (SMTP tem prioridade se ambas estiverem
# preenchidas).

# Opção A — SMTP (Gmail, Outlook, etc.) — não exige domínio verificado
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Opção B — Resend — exige domínio verificado para enviar a destinatários
# externos (sem isso, só envia para o e-mail da própria conta Resend)
RESEND_API_KEY=

# Usado por ambas as opções: o remetente que aparece nos e-mails
EMAIL_FROM=

# Segredo compartilhado que protege a rota do cron de relatórios
# (Vercel Cron envia este valor automaticamente se configurado nas
# variáveis de ambiente do projeto)
CRON_SECRET=
